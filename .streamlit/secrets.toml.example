# Streamlit Cloud Secrets Configuration
# Copy this content to your Streamlit Cloud app's secrets settings
# Go to: App Settings > Secrets

[snowflake]
account = "your-account-identifier"
user = "your-username"
password = "your-password"
warehouse = "COMPUTE_WH"
database = "CENSUS_APP_DB"
schema = "LLM_VIEWS"
role = "ACCOUNTADMIN"
